PORT=3000
NODE_ENV=development

# MongoDB
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>/<db>?retryWrites=true&w=majority

# Auth
JWT_SECRET=change-me

# Optional (used when CV service is available)
CV_SERVICE_URL=http://cv-service:8000

# Optional (if you use Cloudinary upload)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Optional (if you use pawaPay)
PAWAPAY_API_KEY=
PAWAPAY_ENV=sandbox
PAWAPAY_BASE_URL=
PUBLIC_BASE_URL=
APP_PUBLIC_URL=
PAWAPAY_PAYMENT_FLOW=payment_page
PAWAPAY_COUNTRY=SEN
PAWAPAY_CURRENCY=XOF
PAWAPAY_PHONE_COUNTRY_CODE=221
PAWAPAY_LANGUAGE=FR
PAWAPAY_RETURN_URL=
PAWAPAY_CANCEL_URL=
PAWAPAY_PROVIDER=
PAWAPAY_PROVIDER_WAVE=
PAWAPAY_PROVIDER_OM=
